# Copy this file to `.env.local` and fill in real values before connecting a backend.
# Only variables prefixed with VITE_ are exposed to client-side code — never put
# secrets (API keys, signing secrets) here; they belong on the server only.

# Base URL of the real backend API. Leave empty to keep using local mock data.
VITE_API_BASE_URL=

# Force mock mode on/off explicitly. If unset, defaults to true whenever
# VITE_API_BASE_URL is empty.
VITE_USE_MOCK_API=true

# Simulated network latency (ms) for the mock adapter, so loading states remain visible.
VITE_MOCK_LATENCY_MS=500

# Timeout (ms) for real network requests once VITE_API_BASE_URL is set.
VITE_API_TIMEOUT_MS=15000

# development | staging | production
VITE_APP_ENV=development
